
# =========================================================
# DocuPilot Environment Variables
# Copy this file and rename it to .env.local
# Then fill in your own keys.
# =========================================================


# ---------------------------------------------------------
# Gemini AI
# Required for AI features such as:
# - SRS Generator
# - Contract-to-Actions
# - Invoice-to-Approval
# - Scope Guard
# ---------------------------------------------------------

GEMINI_API_KEY=


# ---------------------------------------------------------
# Supabase Database
# Required for backend storage features.
# Used by server-side API routes only.
# Do NOT expose the service role key to the frontend.
# ---------------------------------------------------------

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=


# ---------------------------------------------------------
# Optional public Supabase variables
# Only needed later if the frontend directly uses Supabase.
# Do not use service_role as NEXT_PUBLIC.
# ---------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY= 
